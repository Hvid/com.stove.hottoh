{
  "name": {
    "en": "Pellet Stove",
    "da": "Pilleovn",
    "nl": "Pelletkachel",
    "de": "Pelletofen",
    "fr": "Poêle à granulés",
    "no": "Pelletskamin",
    "sv": "Pelletskamin",
    "fi": "Pellettitakka",
    "it": "Stufa a pellet",
    "es": "Estufa de pellets",
    "pl": "Piec na pellet"
  },
  "class": "heater",
  "capabilities": [
    "onoff",
    "target_temperature",
    "measure_temperature",
    "hottoh_fan_speed",
    "hottoh_power_level",
    "hottoh_smoke_temperature",
    "hottoh_stove_state",
    "hottoh_state_description",
    "hottoh_firmware_version",
    "hottoh_wifi_signal",
    "hottoh_manufacturer",
    "hottoh_stove_state_raw",
    "hottoh_fumes",
    "hottoh_last_error_code",
    "hottoh_last_update_time"
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "compatibility": { "homey": ">=12.2.0" },
  "mobile": {
    "components": [
      {
        "id": "onoff",
        "capabilities": ["onoff"]
      },
      {
        "id": "sensor",
        "capabilities": ["measure_temperature", "target_temperature"]
      },
      {
        "id": "thermostat",
        "capabilities": ["hottoh_power_level", "hottoh_fan_speed"]
      },
      {
        "id": "sensor",
        "capabilities": ["hottoh_fumes", "hottoh_smoke_temperature"]
      },
      {
        "id": "sensor",
        "capabilities": ["hottoh_stove_state"]
      }
    ]
  },
  "pair": [
    { "id": "manual" },
    { "id": "done", "template": "done" }
  ]
}
